# Copy to do/.env on the droplet and fill in secrets.
#   cp do/.env.production.example do/.env

# ── Postgres (internal to compose) ───────────────────────────────────────────
POSTGRES_USER=metricgraph
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=metricgraph

# ── Public API domain (Caddy + Let's Encrypt) ──────────────────────────────────
# Use your real domain, e.g. api.margin.dev
# For IP-only testing without TLS, set API_DOMAIN to localhost and use port 80.
API_DOMAIN=api.yourdomain.com

# ── Auth / CORS ────────────────────────────────────────────────────────────────
AUTH_SECRET=
CORS_ORIGINS=https://margin-app-karman103s-projects.vercel.app,http://localhost:3000

# ── Neo4j Aura (optional for MVP — KG features need this) ─────────────────────
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Cloudflare R2 / S3 (optional for MVP — file uploads need this) ─────────────
S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=metricgraph
S3_REGION=auto
S3_USE_SSL=true

# ── LLM (optional) ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
