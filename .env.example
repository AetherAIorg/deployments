# Production secrets — copy values into DigitalOcean, Vercel, and GitHub repo secrets.
# Do not commit real values.

# ── GitHub: deployments repo Actions ─────────────────────────────────────────
SUBMODULE_PAT=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID_APP=
VERCEL_PROJECT_ID_CATALOG=

# DigitalOcean droplet SSH deploy (GitHub Actions → deploy-do.yml)
DO_HOST=
DO_SSH_USER=root
DO_SSH_KEY=

# ── GitHub: aether_org repo Actions ──────────────────────────────────────────
DEPLOYMENTS_DISPATCH_TOKEN=

# ── GitHub repo variables (non-secret) ───────────────────────────────────────
# DEPLOYMENTS_REPO=AetherAIorg/deployments
# MARGIN_APP_URL=https://margin-app-karman103s-projects.vercel.app
# CATALOG_APP_URL=https://catalog.margin.dev
# API_URL=https://api.yourdomain.com
# PAGES_URL=https://AetherAIorg.github.io/deployments/

# ── DigitalOcean droplet: do/.env (see do/.env.production.example) ───────────
POSTGRES_USER=metricgraph
POSTGRES_PASSWORD=
POSTGRES_DB=metricgraph
API_DOMAIN=api.yourdomain.com
AUTH_SECRET=
CORS_ORIGINS=https://margin-app-karman103s-projects.vercel.app,http://localhost:3000

NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=metricgraph
S3_REGION=auto
S3_USE_SSL=true

OPENROUTER_API_KEY=

# ── Vercel: margin-app ───────────────────────────────────────────────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=Margin <hello@yourdomain.com>
NEXTAUTH_URL=https://margin-app-karman103s-projects.vercel.app
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_CATALOG_URL=https://catalog.margin.dev

# ── Vercel: margin-catalog ───────────────────────────────────────────────────
NEXT_PUBLIC_REGISTRY_URL=https://app.margin.dev

