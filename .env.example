# Production secrets — copy values into Render, Vercel, and GitHub repo secrets.
# Do not commit real values.

# ── GitHub: deployments repo Actions ─────────────────────────────────────────
SUBMODULE_PAT=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID_APP=
VERCEL_PROJECT_ID_CATALOG=

# Render deploy hooks (Dashboard → Service → Settings → Deploy Hook)
RENDER_DEPLOY_HOOK_API=
RENDER_DEPLOY_HOOK_WORKER=
RENDER_DEPLOY_HOOK_HUB=
RENDER_DEPLOY_HOOK_INGEST=
RENDER_DEPLOY_HOOK_CATALOG=

# Optional: Render API key for run-migrations.sh
RENDER_API_KEY=
RENDER_SERVICE_ID_API=
RENDER_SERVICE_ID_CATALOG=

# ── GitHub: aether_org repo Actions ──────────────────────────────────────────
DEPLOYMENTS_DISPATCH_TOKEN=

# ── GitHub repo variables (non-secret) ───────────────────────────────────────
# DEPLOYMENTS_REPO=YOUR_ORG/deployments
# MARGIN_APP_URL=https://app.margin.dev
# CATALOG_APP_URL=https://catalog.margin.dev
# API_URL=https://margin-api.onrender.com
# PAGES_URL=https://YOUR_ORG.github.io/deployments/

# ── Render: margin-api + margin-worker ───────────────────────────────────────
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
AUTH_SECRET=
CORS_ORIGINS=https://app.margin.dev,https://catalog.margin.dev,http://localhost:3000

S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=metricgraph
S3_REGION=auto
S3_USE_SSL=true

OPENROUTER_API_KEY=

# Set after first deploy (use Render external URLs)
INTEGRATION_WEBHOOK_URL=https://margin-hub.onrender.com/webhooks/metricgraph
GOVERNANCE_WEBHOOK_URL=https://catalog-api.onrender.com/webhooks/metricgraph
INTEGRATION_WEBHOOK_SECRET=
GOVERNANCE_WEBHOOK_SECRET=

# ── Render: margin-hub ───────────────────────────────────────────────────────
MARGIN_API_KEY=
HUB_WEBHOOK_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=
LINEAR_TEAM_ID=

# ── Render: margin-ingest ────────────────────────────────────────────────────
INGEST_API_KEY=
HUB_WEBHOOK_URL=https://margin-hub.onrender.com/webhooks/ingest

# ── Render: catalog-api ──────────────────────────────────────────────────────
METRICGRAPH_API_KEY=
WEBHOOK_SECRET=
REGISTRY_BASE_URL=https://app.margin.dev
METRICGRAPH_MATERIALIZE_URL=https://margin-api.onrender.com/api/v1/graph/materialize

# ── Vercel: margin-app ───────────────────────────────────────────────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=Margin <hello@yourdomain.com>
NEXTAUTH_URL=https://app.margin.dev
NEXT_PUBLIC_API_URL=https://margin-api.onrender.com
NEXT_PUBLIC_CATALOG_URL=https://catalog.margin.dev

# ── Vercel: margin-catalog ───────────────────────────────────────────────────
NEXT_PUBLIC_REGISTRY_URL=https://app.margin.dev
